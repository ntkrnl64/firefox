with Files("**"):
    BUG_COMPONENT = ("Core", "Security: Lockstore")

if CONFIG["COMPILE_ENVIRONMENT"]:
    CbindgenHeader(
        "lockstore_ffi_generated.h", inputs=["/security/lockstore/lockstore_ffi"]
    )

    EXPORTS.mozilla.security.lockstore += [
        "!lockstore_ffi_generated.h",
    ]

TEST_DIRS += ["gtest"]
